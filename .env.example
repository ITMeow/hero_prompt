# ============================================================
# hero_prompt environment template
# ============================================================
# HOW TO USE
#   1. cp .env.example .env
#   2. Fill in the values you need.
#   3. For DEMO mode (clone & run, see README):
#        - DATABASE_URL is required
#        - Everything else is optional, the app will use defaults / demo data
#   4. For FULL MODE (Supabase + R2 + AI providers):
#        - Fill in every section you intend to use
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="HeroPrompt"

# theme / appearance
NEXT_PUBLIC_THEME="default"
NEXT_PUBLIC_APPEARANCE="system"
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# ------------------------------------------------------------
# Database (REQUIRED)
# ------------------------------------------------------------
# Demo / local:        postgresql://postgres:postgres@localhost:5432/hero_prompt
# Supabase (direct):   postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
# Supabase (pooler):   postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=""
DATABASE_PROVIDER="postgresql"
DB_SINGLETON_ENABLED="true"
DB_MAX_CONNECTIONS="5"

# ------------------------------------------------------------
# Auth (REQUIRED)
# ------------------------------------------------------------
# openssl rand -base64 32
AUTH_SECRET=""

# OAuth providers (optional, used by /api/auth)
# Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ------------------------------------------------------------
# Object Storage — Cloudflare R2 (default storage provider)
# ------------------------------------------------------------
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY=""
R2_SECRET_KEY=""
R2_BUCKET_NAME=""
# Default upload path prefix (e.g. "uploads" or "uploads/2026")
R2_UPLOAD_PATH="uploads"
# Optional custom endpoint (usually leave empty)
R2_ENDPOINT=""
# Public CDN domain (e.g. https://pub-xxxx.r2.dev or your custom domain)
R2_DOMAIN=""

# AWS S3 (alternative storage, leave empty if using R2)
S3_ENDPOINT=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_DOMAIN=""

# ------------------------------------------------------------
# Payment Providers (optional)
# ------------------------------------------------------------
# Stripe
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_SIGNING_SECRET=""

# PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"   # sandbox | live

# Creem
CREEM_API_KEY=""
CREEM_SIGNING_SECRET=""

# ------------------------------------------------------------
# Email (Resend)
# ------------------------------------------------------------
RESEND_API_KEY=""
RESEND_SENDER_EMAIL=""

# ------------------------------------------------------------
# AI Providers
# ------------------------------------------------------------
# OpenRouter (recommended gateway)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Replicate
REPLICATE_API_TOKEN=""
REPLICATE_CUSTOM_STORAGE="false"

# Fal.ai
FAL_API_KEY=""
FAL_CUSTOM_STORAGE="false"

# Google Gemini
GEMINI_API_KEY=""

# Kie.ai
KIE_API_KEY=""

# Google GenAI SDK
GOOGLE_GENAI_API_KEY=""

# AI SDK / Vercel AI Gateway
AI_GATEWAY_API_KEY=""

# ------------------------------------------------------------
# Analytics / Ads / Support (optional)
# ------------------------------------------------------------
# Umami
UMAMI_WEBSITE_ID=""
UMAMI_SCRIPT_URL=""

# AdSense
ADSENSE_PUBLISHER_ID=""

# Tawk (live chat)
TAWK_PROPERTY_ID=""
TAWK_WIDGET_ID=""

# ------------------------------------------------------------
# Supabase Webhooks (optional, for cache revalidation)
# ------------------------------------------------------------
REVALIDATION_SECRET=""

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
# When using Cloudflare Workers, set to "true" to enable Hyperdrive
USE_HYPERDRIVE="false"
